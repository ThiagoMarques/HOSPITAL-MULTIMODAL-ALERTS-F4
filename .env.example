# Copie para .env:
#   cp .env.example .env

# --- Azure Cognitive Services (obrigatório para áudio) ---
# Crie no portal Azure:
#   1) Recurso "Speech"  → AZURE_SPEECH_KEY + AZURE_SPEECH_REGION
#   2) Recurso "Language" (Text Analytics) → endpoint + key
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=brazilsouth
AZURE_TEXT_ANALYTICS_ENDPOINT=https://SEU_RECURSO.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=

# --- LLM opcional (alertas em linguagem natural, depois) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
