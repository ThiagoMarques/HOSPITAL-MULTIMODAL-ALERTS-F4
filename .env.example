# Copie para .env:
#   cp .env.example .env

# --- Azure Cognitive Services ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=brazilsouth
AZURE_TEXT_ANALYTICS_ENDPOINT=
AZURE_TEXT_ANALYTICS_KEY=

# --- LLM opcional para redigir alertas (Fase 2/3) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Fallback de áudio local ---
# GROQ_API_KEY=
USE_AZURE_SPEECH=false
USE_AZURE_TEXT_ANALYTICS=false
